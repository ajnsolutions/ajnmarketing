# Copy this file to .env.local and fill in real values. Never commit .env.local.

# --- Supabase (public — safe to expose to the browser) ---
# Project URL and anon key, used by every user-facing request path (Server Components,
# Route Handlers reached by the browser, the browser client). Scoped by Row Level Security
# to whichever user is signed in.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (server-only — NEVER expose to the browser) ---
# The project's privileged secret key (Supabase Dashboard -> Project Settings -> API ->
# service_role key, or the newer sb_secret_* key format — both are supported). This key
# bypasses Row Level Security entirely. Only read by lib/supabase/service.ts, and only
# for scheduled/background execution that legitimately needs to operate across tenants
# (not for answering a specific user's request). Do NOT prefix this with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Google OAuth (Google Business Profile integration) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# --- Token encryption ---
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=
