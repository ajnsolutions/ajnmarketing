# Copy this file to .env.local and fill in real values. Never commit .env.local.

# --- Supabase (public — safe to expose to the browser) ---
# Project URL and anon key, used by every user-facing request path (Server Components,
# Route Handlers reached by the browser, the browser client). Scoped by Row Level Security
# to whichever user is signed in.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (server-only — NEVER expose to the browser) ---
# The project's privileged secret key (Supabase Dashboard -> Project Settings -> API ->
# service_role key, or the newer sb_secret_* key format — both are supported). This key
# bypasses Row Level Security entirely. Only read by lib/supabase/service.ts, and only
# for scheduled/background execution that legitimately needs to operate across tenants
# (not for answering a specific user's request). Do NOT prefix this with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Google OAuth (Google Business Profile integration) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# --- Token encryption ---
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# --- Trigger.dev (background task orchestration) ---
# From the Trigger.dev dashboard's project (Settings -> your project's ref, e.g.
# "proj_abcdefghijklmnop"). Not a secret — safe to be a plain constant.
TRIGGER_PROJECT_REF=
# Per-environment API key from the dashboard's API Keys page (dev/staging/prod each get
# their own — use the Dev key locally). Server-only — used by application code that
# triggers tasks (e.g. app/api/admin/trigger-analytics-capture) and by the CLI. Never
# required by task code itself; Trigger.dev's own infrastructure invokes deployed tasks
# directly.
TRIGGER_SECRET_KEY=

# --- Admin allowlist (internal debugging tools only) ---
# Comma-separated Supabase auth user ids (Supabase Dashboard -> Authentication -> Users)
# permitted to call admin-only routes such as app/api/admin/trigger-analytics-capture.
# There is no general role/permission system in this schema — this is a narrow allowlist
# for a small number of privileged developer utilities, not a feature to build on broadly.
ADMIN_USER_IDS=
